# Google Gemini API key. If unset, the server runs in offline demo mode
# with canned AI responses so the app never looks broken.
GEMINI_API_KEY=

# Gemini model used for all AI features (concierge, triage, sitrep, sustainability).
GEMINI_MODEL=gemini-flash-latest

# Port for the Express server (serves API + static client build in production)
PORT=8787

# Simulation seed for reproducible demo runs. Any string works.
SIM_SEED=fifa2026

# Sim speed: how many simulated minutes pass per real second.
SIM_MINUTES_PER_TICK=1
